# Configuration CDN
# Copier ce fichier en .env et modifier les valeurs

# URL de l'API CDN
CDN_URL=http://localhost:8899/api

# Clé API pour l'authentification
# ⚠️ À garder secrète ! Ne jamais exposer côté client
CDN_API_KEY=mysecretkey

# Port du serveur Express (exemples)
PORT=3001

# Environnement (development, production)
NODE_ENV=development
