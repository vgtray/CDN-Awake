# ===========================================
# CDN Production Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# PostgreSQL Database
POSTGRES_DB=cdn_db
POSTGRES_USER=cdn_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# API Configuration
API_KEY=CHANGE_ME_RANDOM_API_KEY
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
ADMIN_SETUP_KEY=CHANGE_ME_SETUP_KEY

# CDN URL (your domain)
CDN_URL=https://yourdomain.com

# Nginx Port (Dokploy will handle this)
NGINX_PORT=80

# File Settings
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.pdf,.zip,.mp4,.mp3,.txt,.json,.css,.html

# Token Settings
TOKEN_EXPIRY_HOURS=24

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cleanup
CLEANUP_INTERVAL_MS=3600000
