# ===========================================
# CDN AWAKE - Environment Configuration
# ===========================================

# ============ DATABASE ============
POSTGRES_DB=cdn_db
POSTGRES_USER=cdn_user
POSTGRES_PASSWORD=your_secure_password_here

# ============ API ============
API_PORT=3000
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

# Admin setup key - used for first admin creation
ADMIN_SETUP_KEY=your_setup_key_here

# ============ FILE SETTINGS ============
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.pdf,.zip,.mp4,.mp3,.txt,.json,.css,.html
TOKEN_EXPIRY_HOURS=24

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============ CLEANUP ============
CLEANUP_INTERVAL_MS=3600000

# ============ NGINX ============
NGINX_PORT=8899

# ============ DASHBOARD ============
CDN_URL=http://localhost:8899
