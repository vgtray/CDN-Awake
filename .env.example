# ================================
# CDN AWAKE - Configuration
# ================================

# Database
POSTGRES_DB=cdn_db
POSTGRES_USER=cdn_user
POSTGRES_PASSWORD=change_this_password

# API
API_KEY=change_this_api_key
JWT_SECRET=change_this_jwt_secret_make_it_long
JWT_EXPIRES_IN=15m
ADMIN_SETUP_KEY=change_this_setup_key

# Files
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.pdf,.zip,.mp4,.mp3,.txt,.json,.css,.js,.html,.svg,.ico,.woff,.woff2
TOKEN_EXPIRY_HOURS=24

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Server
NGINX_PORT=8899
CDN_URL=http://localhost:8899
